NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY= # legacy anon key name, use only if your Supabase project uses this key type.

SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_SECRET_KEY= # optional fallback for server-only admin tasks.
# SUPABASE_DATABASE_PASSWORD= # local CLI/db tasks only. Never expose to the browser.

INITIAL_ADMIN_ID=
INITIAL_ADMIN_PASSWORD=
INITIAL_ADMIN_NAME=슈퍼관리자

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only private-data encryption. Each key is 32 random bytes encoded as base64url.
PRIVATE_DATA_ACTIVE_KEY_VERSION=1
PRIVATE_DATA_KEY_V1=
# Server-only HMAC keys for lookup, rate-limit, audit, and deletion pseudonyms.
SECURITY_HMAC_KEY=
DELETION_HMAC_KEY=

# Hosted Supabase custom provider identifiers and server-side activation flags.
AUTH_CUSTOM_GOOGLE_PROVIDER=custom:google
AUTH_CUSTOM_KAKAO_PROVIDER=custom:kakao
AUTH_CUSTOM_NAVER_PROVIDER=custom:naver
AUTH_GOOGLE_ENABLED=false
AUTH_KAKAO_ENABLED=false
AUTH_NAVER_ENABLED=false

# Guardian identity verification is fail-closed in production until a provider is configured.
GUARDIAN_VERIFICATION_MODE=disabled
GUARDIAN_VERIFICATION_CALLBACK_SECRET=

# Trust forwarded client IPs only on the declared deployment proxy.
TRUSTED_PROXY_MODE=none

# Server-only authorization for scheduled privacy maintenance.
PRIVACY_MAINTENANCE_SECRET=
